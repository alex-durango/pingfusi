#!/usr/bin/env node
// pingfusi — the kit's one command. The kit IS the default: `pingfusi <anything>` goes
// to the enforced workflow (harness/workflow.js), which owns help and unknown-command
// handling. The only exceptions are the review MCP installer's own commands
// (vendor/pingfusi-review.mjs) — none of
// them collide with a kit command, so they pass straight through:
//
//   pingfusi wait|whoami|rules|remove|uninstall   → the MCP installer
//   pingfusi version                              → this package's version
//   pingfusi setup / everything else              → the kit (setup's login step runs the
//                                                   installer's device flow itself)
"use strict";
const path = require("path");

const MCP_COMMANDS = new Set(["remove", "uninstall", "wait", "whoami", "rules"]);

function route(cmd) {
  if (cmd === "version" || cmd === "--version" || cmd === "-v") return "version";
  return MCP_COMMANDS.has(cmd) ? "mcp" : "kit";
}

// `remove`/`uninstall` also sweep the kit's own clone/fix skills. A scoped remove
// touches only that coding agent; a full remove sweeps every supported skill dir.
const VALID_CLIENTS = ["claude-code", "cursor", "codex", "claude-desktop"];

function kitSkillClient(argv) {
  for (let i = 1; i < argv.length; i++) {
    if (argv[i] === "--client") {
      const value = String(argv[i + 1] ?? "").toLowerCase();
      // A missing/mistyped value must be a hard error, never a scope widening: "" used
      // to fall through to removeSkills, whose falsy-client path sweeps EVERY client.
      if (!VALID_CLIENTS.includes(value)) {
        throw new Error(`--client needs one of: ${VALID_CLIENTS.join(", ")}${value ? ` (got "${value}")` : " (got nothing)"}`);
      }
      return value;
    }
    if (argv[i] === "--code" || argv[i] === "--claude-code") return "claude-code";
    if (argv[i] === "--cursor") return "cursor";
    if (argv[i] === "--codex") return "codex";
    if (argv[i] === "--claude" || argv[i] === "--claude-desktop") return "claude-desktop";
  }
  return null;
}

function sweepsKitSkills(argv) {
  if (argv[0] !== "remove" && argv[0] !== "uninstall") return false;
  const client = kitSkillClient(argv);
  return client !== "claude-desktop"; // desktop has MCP config but no coding-agent skills
}

function main() {
  const r = route(process.argv[2]);
  if (r === "version") { console.log(require("../package.json").version); return; }
  if (r === "kit") return require("../harness/workflow.js").main();
  const argv = process.argv.slice(2);
  if (argv[0] === "remove" || argv[0] === "uninstall") {
    // Validate the client scope BEFORE anything destructive runs (kit sweep or the
    // vendored installer) — kitSkillClient throws on a malformed/absent --client value.
    let client;
    try { client = kitSkillClient(argv); }
    catch (e) { console.error(`✗ ${e.message}`); process.exit(2); }
    if (sweepsKitSkills(argv)) {
      try {
        const removed = require("../harness/agent-setup.js").removeSkills(require("os").homedir(), client);
        if (removed.length) console.log(`✓ Removed kit agent skill(s): ${removed.join(", ")}`);
      } catch { /* best-effort — the installer's own removal still runs */ }
    }
  }
  // ESM with top-level await — must be import()ed; it re-reads process.argv itself.
  import(require("url").pathToFileURL(path.join(__dirname, "..", "vendor", "pingfusi-review.mjs")).href)
    .catch((e) => { console.error(`✗ ${(e && e.message) || e}`); process.exit(1); });
}

if (require.main === module) main();
module.exports = { route, MCP_COMMANDS, kitSkillClient, sweepsKitSkills };
